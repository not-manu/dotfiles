#!/bin/sh
# Global hook (core.hookspath) — runs in EVERY repo, including ones that don't
# use LFS. Some tools (notably Homebrew's auto-update) invoke git with a
# sanitized PATH that omits /opt/homebrew/bin, so add it back explicitly.
PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v git-lfs >/dev/null 2>&1; then
	# Only block the push if this repo actually tracks files with LFS —
	# pushing LFS pointers without uploading objects would corrupt the remote.
	top=$(git rev-parse --show-toplevel 2>/dev/null)
	if [ -n "$top" ] && [ -f "$top/.gitattributes" ] && grep -q 'filter=lfs' "$top/.gitattributes" 2>/dev/null; then
		printf >&2 "error: this repository uses Git LFS but 'git-lfs' was not found on PATH; aborting push.\n"
		exit 2
	fi
	exit 0
fi

git lfs pre-push "$@"
