#!/usr/bin/env bash
# servermode — keep the Mac awake with the lid closed (mini-server mode).
# Usage: servermode on|off|status
set -euo pipefail

status() {
  if pmset -g | grep -q 'SleepDisabled.*1'; then
    echo "server mode: ON (lid close will NOT sleep)"
  else
    echo "server mode: OFF (normal sleep behavior)"
  fi
  pmset -g batt | sed -n 2p
}

case "${1:-status}" in
  on)
    sudo pmset -a disablesleep 1
    echo "server mode ON — machine stays awake with lid closed."
    # warn if on battery, since disablesleep will happily drain it
    if pmset -g batt | grep -q 'Battery Power'; then
      echo "⚠️  running on battery — plug in or this will drain fast."
    fi
    ;;
  off)
    sudo pmset -a disablesleep 0
    echo "server mode OFF — normal sleep restored."
    ;;
  status) status ;;
  tmux)
    # status-line segment: red power glyph when server mode is on, nothing when off
    if pmset -g | grep -q 'SleepDisabled.*1'; then
      printf '#[fg=#d14d41,bold]⏻ SRV #[default]'
    fi
    ;;
  *)
    echo "usage: servermode on|off|status" >&2
    exit 1
    ;;
esac
