#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
gp: background git push with per-repo spam protection

Usage:
  gp              start git push in background and return immediately
  gp --wait       run git push in the foreground, still using the lock
  gp --status     show whether a push is already running
  gp --log        print the last push log
  gp -- <args>    pass args to git push

Logs: .git/gp.log
EOF
}

die() {
  printf 'gp: %s\n' "$*" >&2
  exit 1
}

mode="background"
case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  --wait)
    mode="wait"
    shift
    ;;
  --status)
    mode="status"
    shift
    ;;
  --log)
    mode="log"
    shift
    ;;
  --)
    shift
    ;;
esac

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not inside a git repo"
cd "$repo_root"

git_dir=$(git rev-parse --git-common-dir 2>/dev/null) || die "could not resolve git dir"
case "$git_dir" in
  /*) ;;
  *) git_dir="$repo_root/$git_dir" ;;
esac

lock_dir="$git_dir/gp.lock"
log_file="$git_dir/gp.log"
pid_file="$lock_dir/pid"

is_running() {
  [[ -f "$pid_file" ]] || return 1
  local pid
  pid=$(<"$pid_file")
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

case "$mode" in
  status)
    if is_running; then
      printf 'gp: push already running in %s (pid %s)\n' "$repo_root" "$(<"$pid_file")"
    else
      printf 'gp: no push running in %s\n' "$repo_root"
    fi
    exit 0
    ;;
  log)
    [[ -f "$log_file" ]] || die "no log yet: $log_file"
    exec less -R "$log_file"
    ;;
esac

if ! mkdir "$lock_dir" 2>/dev/null; then
  if is_running; then
    printf 'gp: push already running in %s (pid %s)\n' "$repo_root" "$(<"$pid_file")"
    exit 0
  fi

  rm -rf "$lock_dir"
  mkdir "$lock_dir" || die "could not acquire push lock"
fi

cleanup() {
  rm -rf "$lock_dir"
}

run_push() {
  printf '%s\n' "$BASHPID" > "$pid_file"
  trap cleanup EXIT INT TERM

  {
    printf '== gp started: %s ==\n' "$(date)"
    printf 'repo: %s\n' "$repo_root"
    printf 'cmd: git push'
    if (($#)); then
      printf ' %q' "$@"
    fi
    printf '\n\n'

    git push "$@"
    status=$?

    printf '\n== gp finished: %s, status %s ==\n' "$(date)" "$status"
    exit "$status"
  } > "$log_file" 2>&1
}

if [[ "$mode" == "wait" ]]; then
  run_push "$@"
fi

(
  run_push "$@"
) >/dev/null 2>&1 &

printf '%s\n' "$!" > "$pid_file"
disown 2>/dev/null || true
printf 'gp: pushing in background: %s\n' "$repo_root"
printf 'gp: log: %s\n' "$log_file"
