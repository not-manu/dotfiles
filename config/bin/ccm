#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
ccm: list available Claude (Anthropic API) models

Usage:
  ccm                list models (newest first): id · name · context
  ccm --ids          print model ids only (one per line)
  ccm --json         print the raw API JSON
  ccm --limit <n>    number of models to fetch (1-1000, default 100)

Auth:
  Reads ANTHROPIC_API_KEY from the environment.
EOF
}

die() {
  printf 'ccm: %s\n' "$*" >&2
  exit 1
}

mode="table"
limit=100

while (($#)); do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --ids)     mode="ids"; shift ;;
    --json)    mode="json"; shift ;;
    --limit)   limit="${2:-}"; [[ -n "$limit" ]] || die "--limit needs a value"; shift 2 ;;
    *)         die "unknown argument: $1 (try --help)" ;;
  esac
done

command -v jq >/dev/null 2>&1 || die "jq is required (brew install jq)"
[[ -n "${ANTHROPIC_API_KEY:-}" ]] || die "ANTHROPIC_API_KEY is not set (see script header)"

resp=$(curl -sS --fail-with-body "https://api.anthropic.com/v1/models?limit=${limit}" \
  -H 'anthropic-version: 2023-06-01' \
  -H "x-api-key: ${ANTHROPIC_API_KEY}") || die "API request failed: $resp"

case "$mode" in
  json)
    printf '%s\n' "$resp" | jq .
    ;;
  ids)
    printf '%s\n' "$resp" | jq -r '.data[].id'
    ;;
  table)
    printf '%s\n' "$resp" | jq -r '
      .data[]
      | [ .id, .display_name, ( (.max_input_tokens // 0 | tostring) + " ctx") ]
      | @tsv' | column -t -s $'\t'
    ;;
esac
